{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "finspark-financial",
  "compatibility_date": "2024-12-30",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],

  // CPU 时间限制：提高到 5 分钟（300,000ms），需要 Workers Paid 计划（$5/月）
  // 默认 30 秒，评估任务（每题 4 次 LLM 调用）经常超时
  // 参考：https://developers.cloudflare.com/workers/platform/limits/#cpu-time
  "limits": {
    "cpu_ms": 300000
  },

  // D1 数据库（股票数据、用户数据、分析报告持久化）
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "genspark-financial-db",
      "database_id": "af997515-df86-457d-bec1-f29e634f2a90"
    }
  ],

  // KV 缓存存储（Tushare 数据缓存和分析结果临时存储）
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "285fe51274154c798eaccafd90489666"
    }
  ],

  // Vectorize 向量数据库（RAG 语义检索，替代 KV 全扫方案）
  // 
  // ⚠️ 启用前必须先通过 wrangler CLI 创建索引，否则部署会报错：
  //   npx wrangler vectorize create finspark-rag-index --dimensions=1024 --metric=cosine
  //   npx wrangler vectorize create-metadata-index finspark-rag-index --property-name=stock_code --type=string
  //   npx wrangler vectorize create-metadata-index finspark-rag-index --property-name=document_id --type=number
  //   npx wrangler vectorize create-metadata-index finspark-rag-index --property-name=category --type=string
  //
  // 索引创建完成后，取消下方注释即可启用 Vectorize 加速检索（代码已内置降级逻辑）
  //
  // "vectorize": [
  //   {
  //     "binding": "VECTORIZE",
  //     "index_name": "finspark-rag-index"
  //   }
  // ]

  // 环境变量已在 Cloudflare Dashboard 中配置:
  // - AKSHARE_PROXY_URL: http://47.110.92.210:8000
  // - VECTORENGINE_API_KEY, TUSHARE_TOKEN, JWT_SECRET 等
  // - MINERU_API_KEY: MinerU PDF智能解析 (上海AI实验室 OpenDataLab)
  // - DASHSCOPE_API_KEY: 阿里云百炼 (通义千问 text-embedding-v4 向量化, 1024维, 中文优化)

  // R2 存储（用于漫画图片等文件 - 后续添加）
  // "r2_buckets": [
  //   {
  //     "binding": "STORAGE",
  //     "bucket_name": "genspark-financial-storage"
  //   }
  // ]
}
